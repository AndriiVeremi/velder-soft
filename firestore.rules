rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Вхід в систему
    function isSignedIn() {
      return request.auth != null;
    }

    // Отримання даних користувача
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Перевірка ролі Директора
    function isDirector() {
      return isSignedIn() && getUserData().role == 'DIRECTOR';
    }
    
    // Перевірка активності акаунту
    function isActive() {
      return isSignedIn() && getUserData().isActive == true;
    }

    // Перевірка, чи поле не змінюється
    function isUnchanged(key) {
      return request.resource.data[key] == resource.data[key];
    }

    // --- КОРИСТУВАЧІ ---
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isDirector());
      allow create: if isSignedIn() && 
                    request.resource.data.role == 'EMPLOYEE' && 
                    request.resource.data.isActive == false;
      allow update: if isSignedIn() && (
        isDirector() || 
        (request.auth.uid == userId && 
         isUnchanged('role') && 
         isUnchanged('isActive'))
      );
      allow delete: if isDirector();
    }

    // --- ПРОЄКТИ ---
    match /projects/{id} {
      allow read: if isSignedIn();
      allow write: if isDirector();
    }
    match /hospitals/{id} {
      allow read: if isSignedIn();
      allow write: if isDirector();
    }
    match /departments/{id} {
      allow read: if isSignedIn();
      allow write: if isDirector();
    }

    // --- ЗАВДАННЯ ---
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow create: if isDirector();
      allow update: if isSignedIn() && (
        isDirector() || 
        ((resource.data.assignedTo == request.auth.uid || resource.data.assignedTo == 'all') && 
         isUnchanged('title') && 
         isUnchanged('description') && 
         isUnchanged('assignedTo') &&
         isUnchanged('date'))
      );
      allow delete: if isDirector();
    }

    // --- ОГОЛОШЕННЯ ---
    match /announcements/{id} {
      allow read: if isSignedIn();
      allow create, update, delete: if isDirector();
    }

    // --- ВІДПУСТКИ ---
    match /vacations/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isDirector() || (
        isSignedIn() && resource.data.userId == request.auth.uid && isUnchanged('status')
      );
      allow delete: if isDirector() || (isSignedIn() && resource.data.userId == request.auth.uid && resource.data.status == 'PENDING');
    }

    // --- НАГАДУВАННЯ ---
    match /reminders/{id} {
      allow read, create, update, delete: if isSignedIn() && (
        (resource == null || resource.data.userId == request.auth.uid) &&
        (request.resource == null || request.resource.data.userId == request.auth.uid)
      );
    }

    // --- ЗВІТИ ПРО ПРОБЛЕМИ ---
    match /reports/{id} {
      allow read: if isDirector();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isDirector();
    }

    // --- ЛІНІЯ ДО ШЕФА ---
    match /requests/{id} {
      allow read: if isDirector() || (isSignedIn() && resource.data.senderId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow update: if isDirector();
      allow delete: if isDirector() || (isSignedIn() && resource.data.senderId == request.auth.uid);
    }

    // --- СЕРВІС ---
    match /services/{id} {
      allow read: if isSignedIn();
      allow create: if isDirector();
      allow update: if isDirector() || (isSignedIn() && isUnchanged('hospital') && isUnchanged('department') && isUnchanged('status'));
      allow delete: if isDirector();
    }

    // --- ДОКУМЕНТАЦІЯ ---
    match /docs_categories/{id} {
      allow read: if isSignedIn();
      allow write: if isDirector();
    }
    match /docs_folders/{id} {
      allow read: if isSignedIn();
      allow write: if isDirector();
    }
    match /docs_files/{id} {
      allow read: if isSignedIn();
      allow write: if isDirector();
    }
  }
}
